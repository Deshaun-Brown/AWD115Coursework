@model Fitness_Tracker.Models.Order

@{
    ViewData["Title"] = "Order Confirmation (Admin)";
}

<div class="max-w-3xl mx-auto mt-8">
    <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>

    <div class="mt-4 rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm text-slate-700">
            <div><span class="font-semibold">Order #:</span> @Model.OrderId</div>
            <div><span class="font-semibold">Date:</span> @Model.OrderDate.ToString("g")</div>
            <div><span class="font-semibold">Total:</span> @Model.TotalAmount.ToString("C")</div>
            <div><span class="font-semibold">Status:</span> @Model.Status</div>
        </div>

        <h2 class="mt-6 text-lg font-semibold">Items</h2>
        <div class="mt-2 overflow-hidden rounded-md border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Product</th>
                        <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-slate-600">Price</th>
                        <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-slate-600">Qty</th>
                        <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-slate-600">Line total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="px-4 py-2 text-sm text-slate-800">@item.Product?.Name</td>
                            <td class="px-4 py-2 text-right text-sm text-slate-700">@item.Price.ToString("C")</td>
                            <td class="px-4 py-2 text-right text-sm text-slate-700">@item.Quantity</td>
                            <td class="px-4 py-2 text-right text-sm text-slate-700">@((item.Price * item.Quantity).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-6">
            <a asp-area="" asp-controller="Order" asp-action="Index" class="btn-link">Back to Products</a>
        </div>
    </div>
</div>
