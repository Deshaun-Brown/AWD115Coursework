@model Fitness_Tracker.ViewModels.AdminOrderFormViewModel

@{
    ViewData["Title"] = "Create Order";
}

<div class="mx-auto max-w-3xl rounded-xl border border-slate-200 bg-white">
    <div class="border-b border-slate-200 px-6 py-4">
        <h1 class="text-lg font-semibold">@ViewData["Title"]</h1>
        <p class="mt-1 text-sm text-slate-600">Create an order and add an initial product line item.</p>
    </div>

    <form asp-area="Admin" asp-controller="Orders" asp-action="Create" method="post" class="px-6 py-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800"></div>

        <div class="grid gap-4">
            <div>
                <label asp-for="CustomerName" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="CustomerName" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" />
                <span asp-validation-for="CustomerName" class="mt-1 block text-sm text-rose-700"></span>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label asp-for="OrderDate" class="block text-sm font-medium text-slate-700"></label>
                    <input asp-for="OrderDate" type="datetime-local" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" />
                </div>
                <div>
                    <label asp-for="Status" class="block text-sm font-medium text-slate-700"></label>
                    <select asp-for="Status" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
                        @foreach (var status in Enum.GetValues<Fitness_Tracker.Models.Order.OrderStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label asp-for="SelectedProductId" class="block text-sm font-medium text-slate-700">Initial Product</label>
                    <select asp-for="SelectedProductId" asp-items="Model.Products" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
                        <option value="">-- Select a product --</option>
                    </select>
                    <span asp-validation-for="SelectedProductId" class="mt-1 block text-sm text-rose-700"></span>
                </div>
                <div>
                    <label asp-for="SelectedQuantity" class="block text-sm font-medium text-slate-700">Quantity</label>
                    <input asp-for="SelectedQuantity" min="1" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" />
                    <span asp-validation-for="SelectedQuantity" class="mt-1 block text-sm text-rose-700"></span>
                </div>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-2">
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="rounded-md px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">Cancel</a>
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Create</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
