@model Fitness_Tracker.ViewModels.AdminUserEditViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="mx-auto max-w-2xl rounded-xl border border-slate-200 bg-white">
    <div class="border-b border-slate-200 px-6 py-4">
        <h1 class="text-lg font-semibold">@ViewData["Title"]</h1>
        <p class="mt-1 text-sm text-slate-600">Update user email and roles.</p>
    </div>

    <form asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="px-6 py-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800"></div>

        <div class="grid gap-4">
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-slate-700"></label>
                <input asp-for="Email" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" />
                <span asp-validation-for="Email" class="mt-1 block text-sm text-rose-700"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Roles</label>
                <div class="mt-2 grid gap-2 rounded-md border border-slate-200 bg-slate-50 p-4">
                    @foreach (var role in Model.AllRoles)
                    {
                        <label class="inline-flex items-center gap-2 text-sm text-slate-700">
                            <input type="checkbox" name="SelectedRoles" value="@role" @(Model.SelectedRoles.Contains(role) ? "checked" : "") class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                            <span>@role</span>
                        </label>
                    }
                </div>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-2">
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="rounded-md px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">Cancel</a>
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Save</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
