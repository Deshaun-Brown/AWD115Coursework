    <!-- Chat UI -->
    <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-medium">Ask the store agent</h3>
        <p class="mt-1 text-sm text-slate-600">Ask about products, inventory or categories.</p>

        <div id="chatContainer" class="mt-4 flex flex-col gap-4">
            <ul id="chatMessages" class="max-h-60 space-y-3 overflow-auto px-2" aria-live="polite"></ul>

            <form id="chatForm" class="mt-2 flex gap-2">
                <input id="questionInput" type="text" autocomplete="off" placeholder="Ask a question..."
                       class="min-w-0 flex-1 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm" />
                <button id="sendBtn" type="submit"
                        class="inline-flex items-center rounded-md bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700">
                    Send
                </button>
            </form>
        </div>
    </div>
        </div>
    </div>

    <!-- AI Agent panel -->
    <div class="mt-8">
        <h2 class="text-xl font-semibold">AI Agent</h2>
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-slate-200 bg-white p-4">
                <h3 class="text-sm font-medium">Product summary</h3>
                <p class="mt-2 text-3xl font-semibold">@Model.ProductCount</p>
                <p class="mt-1 text-sm text-slate-600">Total products in the store</p>
            </div>

            <div class="col-span-2 rounded-lg border border-slate-200 bg-white p-4">
                <h3 class="text-sm font-medium">Recent products</h3>
                <ul class="mt-3 space-y-2 text-sm text-slate-700">
                    @foreach (var p in Model.RecentProducts)
                    {
                        <li class="flex items-center justify-between">
                            <span>@p.Name</span>
                            <span class="text-slate-500">@String.Format("${0:0.00}", p.Price)</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="mt-6 rounded-lg border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-medium">AI readiness & quick answer</h3>
        <div class="mt-2 text-sm text-slate-700">
            <p>AI agent configured: <strong>@(Model.AiReady ? "Yes" : "No")</strong></p>
            @if (!string.IsNullOrEmpty(Model.MostExpensiveProductName))
            {
                <p class="mt-1">Most expensive product: <strong>@Model.MostExpensiveProductName</strong> — <span class="text-slate-500">@String.Format("${0:0.00}", Model.MostExpensiveProductPrice)</span></p>
            }
            else
            {
                <p class="mt-1 text-slate-500">No products available.</p>
            }

            <div class="mt-3">
                <h4 class="text-sm font-medium">AI answer</h4>
                <p id="aiQuickAnswer" class="mt-1 text-sm text-slate-700">@(Model.AiReady ? "Asking AI..." : "AI not configured.")</p>
            </div>
        </div>
    </div>

