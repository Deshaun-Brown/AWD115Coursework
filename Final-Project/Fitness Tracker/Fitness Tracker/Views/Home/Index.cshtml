@model Fitness_Tracker.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="mx-auto max-w-6xl">
    <div class="grid items-center gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
            <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
                Fitness Tracker Store
            </h1>
            <p class="mt-4 max-w-2xl text-lg text-slate-600">
                Manage your products, categories, and inventory, with secure sign-in powered by ASP.NET Core Identity.
            </p>

            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                <a href="/products"
                   class="inline-flex items-center justify-center rounded-md bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                    Browse Products
                </a>
                <a href="/products/browse"
                   class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                    Browse Equipment
                </a>
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Create"
                           class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                            Add a Product
                        </a>
                    }
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login"
                       class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                        Login
                    </a>
                }
            </div>

@section Scripts {
    <script>
        (function () {
            const chatForm = document.getElementById('chatForm');
            const questionInput = document.getElementById('questionInput');
            const chatMessages = document.getElementById('chatMessages');
            const sendBtn = document.getElementById('sendBtn');

            function addMessage(who, text, toneClass) {
                const li = document.createElement('li');
                li.className = 'flex items-start gap-3';

                const bubble = document.createElement('div');
                bubble.className = `rounded-md px-3 py-2 text-sm ${toneClass}`;
                bubble.textContent = text;

                const label = document.createElement('div');
                label.className = 'text-xs text-slate-500';
                label.textContent = who;

                const wrapper = document.createElement('div');
                wrapper.appendChild(label);
                wrapper.appendChild(bubble);

                li.appendChild(wrapper);
                chatMessages.appendChild(li);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            if (chatForm) {
                chatForm.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const question = questionInput.value.trim();
                    if (!question) return;

                    // Add user message
                    addMessage('You', question, 'bg-indigo-100');
                    questionInput.value = '';
                    sendBtn.disabled = true;
                    sendBtn.textContent = '...';

                    try {
                        const res = await fetch('/api/chat/ask', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ question })
                        });

                        const data = await res.json();

                        if (res.ok) {
                            addMessage('StoreAgent', data.answer || 'No answer.', 'bg-gray-100');
                        } else {
                            addMessage('StoreAgent', data?.error || 'Sorry, something went wrong.', 'bg-red-100');
                        }
                    } catch (err) {
                        addMessage('StoreAgent', 'Network error. Try again.', 'bg-red-100');
                    } finally {
                        sendBtn.disabled = false;
                        sendBtn.textContent = 'Send';
                    }
                });
            }
        })();
    </script>
    <script>
        (function () {
            // Auto-query the AI agent for the most expensive product when the page loads,
            // but only if the server-side check indicated the API key is configured.
            const aiReady = @(Model.AiReady ? "true" : "false");
            if (!aiReady) return;

            async function askMostExpensive() {
                try {
                    const res = await fetch('/api/chat/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ question: 'what is the most expensive product?' })
                    });

                    const data = await res.json();
                    const el = document.getElementById('aiQuickAnswer');
                    if (!el) return;

                    if (res.ok) {
                        el.textContent = data.answer || 'No answer from AI.';
                    } else {
                        el.textContent = data?.error || 'AI returned an error.';
                    }
                } catch (err) {
                    const el = document.getElementById('aiQuickAnswer');
                    if (el) el.textContent = 'Network error while asking AI.';
                }
            }

            // Fire-and-forget; update UI when response arrives.
            askMostExpensive();
        })();
    </script>
}
