@model Fitness_Tracker.ViewModels.ProductCategoryViewModel

<h2 class="text-2xl font-bold mb-4">Browse Products</h2>

<div class="flex gap-8">
    <div>
        <h3 class="font-semibold mb-2">Category</h3>
        <ul>
            <li>
                <a href="@Url.RouteUrl("ProductsBrowse", new { category = "all" })"
                   class="@(Model.SelectedCategory == "all" ? "font-bold text-green-600" : "text-slate-700")">
                    All
                </a>
            </li>
            @foreach (var cat in Model.Categories)
            {
                <li>
                    <a href="@Url.RouteUrl("ProductsBrowse", new { category = cat.Name })"
                       class="@(Model.SelectedCategory == cat.Name ? "font-bold text-green-600" : "text-slate-700")">
                        @cat.Name
                    </a>
                </li>
            }
        </ul>
    </div>
    <div class="flex-1">
        <h3 class="font-semibold mb-2">Products</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @{ var idx = 0; }
            @foreach (var prod in Model.Products)
            {
                <div style="animation-delay:@(idx * 80)ms" class="rounded border p-4 bg-white animate-fall-in transform transition-transform duration-200 ease-out hover:-translate-y-3 hover:shadow-2xl hover:z-10 will-change-transform relative cursor-pointer">
                    <div class="font-semibold">@prod.Name</div>
                    <div class="text-sm text-slate-600">@prod.Description</div>
                    <div class="text-xs text-slate-400 mt-2">@prod.Category?.Name</div>
                </div>
                idx++;
            }
        </div>
    </div>
</div>
