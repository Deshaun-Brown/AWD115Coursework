<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    @{
        ViewData["Title"] = "Get Fit with Our Store"; 
    }
    <link href="~/css/output.css" rel="stylesheet"  asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    var isProductsIndex = (currentController == "Product" || currentController == "Order") && currentAction == "Index";
    var isIdentityLogin = currentArea == "Identity" && string.Equals(currentPage, "/Account/Login", StringComparison.OrdinalIgnoreCase);
    var isIdentityRegister = currentArea == "Identity" && string.Equals(currentPage, "/Account/Register", StringComparison.OrdinalIgnoreCase);
    var isAdminProductCreate = currentArea == "Admin" && currentController == "Product" && currentAction == "Create";
}

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@inject Fitness_Tracker.Data.IDatabaseAgent DatabaseAgent

@{
    // Server-side cart count so badge is not rendered unless there are items.
    var serverCartCount = 0;
    if (User?.Identity?.IsAuthenticated ?? false)
    {
        var userId = UserManager.GetUserId(User);
        if (!string.IsNullOrEmpty(userId))
        {
            var items = await DatabaseAgent.GetCartItemsForUserAsync(userId);
            serverCartCount = items?.Sum(i => i.Quantity) ?? 0;
        }
    }
}

     <script src="https://cdn.jsdelivr.net/npm/@@tailwindplus/elements@1" type="module"></script>
    <!--
      This example requires updating your template:

      ```
      <html class="h-full bg-gray-900">
      <body class="h-full">
      ```
    -->
    <header class="border-b border-slate-200 bg-white">
        <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 items-center justify-between">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 font-semibold">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-r from-green-500 to-black text-white">FT</span>
                    <span>Fitness Tracker</span>
                </a>

                <!-- removed center hamburger; right-side hamburger is used -->

                <!-- Desktop nav -->
                <div class="flex items-center gap-2">
                    <!-- Cart icon with badge -->
                    <a asp-controller="Cart" asp-action="Index" class="btn-link ml-3 flex items-center gap-2 relative" title="View cart">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 3h2l.4 2M7 13h10l4-8H5.4" stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="10" cy="20" r="1" />
                            <circle cx="18" cy="20" r="1" />
                        </svg>
                        @if (serverCartCount > 0)
                        {
                            <span id="cart-count" class="absolute -top-1 -right-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-rose-600 text-xs text-white">@serverCartCount</span>
                        }
                        else
                        {
                            <span id="cart-count" class="hidden absolute -top-1 -right-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-rose-600 text-xs text-white"></span>
                        }
                    </a>

                    <!-- Hamburger (always visible) -->
                    <button id="nav-toggle" type="button"
                            class="inline-flex items-center rounded-md p-2 text-slate-700 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-green-500"
                            aria-controls="mobile-nav" aria-expanded="false">
                        <span class="sr-only">Open main menu</span>
                        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile nav -->
            <div id="mobile-nav" class="hidden border-t border-slate-200 py-3">
                <div class="flex flex-col gap-2">
                    @if (!isProductsIndex)
                    {
                        <a asp-controller="Order" asp-action="Index" class="btn-link">Products</a>
                    }

                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" class="inline">
                            <button type="submit" class="btn-link">Logout</button>
                        </form>
                    }
                    else
                    {
                        @if (!isIdentityRegister)
                        {
                            <a asp-area="Identity" asp-page="/Account/Register" class="btn-link">Register</a>
                        }
                        @if (!isIdentityLogin)
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn-link">Login</a>
                        }
                    }

                    @if (User?.Identity?.IsAuthenticated ?? false && User.IsInRole("Admin") && !isAdminProductCreate)
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Create">Add Product</a>
                    }
                    <a asp-controller="Cart" asp-action="Index" class="btn-link">Cart</a>
                </div>
            </div>
        </nav>
    </header>

    <!-- reduced top padding so page hero sits closer to the top of the viewport -->
    <main class="mx-auto w-full max-w-6xl px-4 pt-4 pb-8 sm:px-6 lg:px-8">
        @RenderBody()
    </main>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-6 text-sm text-slate-600 sm:px-6 lg:px-8">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <span>&copy; @DateTime.Now.Year - Fitness Tracker</span>
                <span>Built with ASP.NET Core MVC + Tailwind CSS</span>
            </div>
        </div>
    </footer>

    <script>
        (function () {
            const toggle = document.getElementById('nav-toggle');
            const menu = document.getElementById('mobile-nav');
            if (!toggle || !menu) return;

            toggle.addEventListener('click', function () {
                const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', String(!isExpanded));
                menu.classList.toggle('hidden');
            });

            // Update cart count from server via fetch (optional)
            async function updateCartCount() {
                try {
                    const res = await fetch('/cart/count');
                    if (!res.ok) return;
                    const data = await res.json();
                    const el = document.getElementById('cart-count');
                    if (!el) return;
                    const count = Number(data?.count) || 0;
                    if (count > 0) {
                        el.textContent = String(count);
                        el.classList.remove('hidden');
                    } else {
                        el.textContent = '';
                        el.classList.add('hidden');
                    }
                } catch { }
            }

            // Try to update on load
            updateCartCount();

            // Attach listener for AJAX add-to-cart forms to update badge without reload
            document.addEventListener('submit', async function (e) {
                const form = e.target;
                if (!form.classList || !form.classList.contains('js-add-to-cart')) return;
                e.preventDefault();

                const url = form.action;
                const formData = new FormData(form);
                try {
                    const res = await fetch(url, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData
                    });

                    // After add, refresh count
                    await updateCartCount();

                    // If server redirected, follow it
                    if (res.redirected) {
                        window.location.href = res.url;
                    }
                } catch (err) {
                    console.error(err);
                }
            });
        })();
    </script>

    <!-- Global AI Agent widget (bottom-right) -->
    <div id="aiAgentWidget" class="fixed inset-x-4 bottom-6 z-50 flex justify-end">
        <div id="aiAgentPanel" class="hidden w-[360px] max-w-full rounded-xl border border-slate-200 bg-white shadow-lg">
            <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
                <div class="text-sm font-medium">Store Agent</div>
                <button id="aiAgentClose" class="text-slate-500 hover:text-slate-700">✕</button>
            </div>
            <div class="px-3 py-2">
                <ul id="layoutChatMessages" class="max-h-48 space-y-2 overflow-auto text-sm text-slate-700"></ul>

                <form id="layoutChatForm" class="mt-3 flex gap-2">
                    <input id="layoutQuestionInput" type="text" autocomplete="off" placeholder="Ask about products or inventory..."
                           class="min-w-0 flex-1 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm" />
                    <button id="layoutSendBtn" type="submit"
                            class="inline-flex items-center rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white hover:bg-green-700">
                        Send
                    </button>
                </form>
            </div>
        </div>

        <button id="aiAgentToggle" title="Ask the store agent"
                class="ml-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-green-600 text-white shadow-md hover:bg-green-700">
            💬
        </button>
    </div>

    <script>
        (function () {
            const toggle = document.getElementById('aiAgentToggle');
            const panel = document.getElementById('aiAgentPanel');
            const closeBtn = document.getElementById('aiAgentClose');
            const chatForm = document.getElementById('layoutChatForm');
            const questionInput = document.getElementById('layoutQuestionInput');
            const chatMessages = document.getElementById('layoutChatMessages');
            const sendBtn = document.getElementById('layoutSendBtn');

            function addMessage(who, text, toneClass) {
                const li = document.createElement('li');
                const label = document.createElement('div');
                label.className = 'text-xs text-slate-500';
                label.textContent = who;

                const bubble = document.createElement('div');
                bubble.className = `rounded-md px-3 py-2 text-sm ${toneClass}`;
                bubble.textContent = text;

                li.appendChild(label);
                li.appendChild(bubble);
                chatMessages.appendChild(li);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            if (toggle && panel) {
                toggle.addEventListener('click', () => panel.classList.toggle('hidden'));
            }
            if (closeBtn && panel) {
                closeBtn.addEventListener('click', () => panel.classList.add('hidden'));
            }

            if (chatForm) {
                chatForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const question = questionInput.value.trim();
                    if (!question) return;

                    addMessage('You', question, 'bg-indigo-100');
                    questionInput.value = '';
                    sendBtn.disabled = true;
                    sendBtn.textContent = '...';

                    try {
                        const res = await fetch('/api/chat/ask', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ question })
                        });

                        const data = await res.json();
                        if (res.ok) {
                            addMessage('StoreAgent', data.answer || 'No answer.', 'bg-gray-100');
                        } else {
                            addMessage('StoreAgent', data?.error || 'Sorry, something went wrong.', 'bg-red-100');
                        }
                    } catch (err) {
                        addMessage('StoreAgent', 'Network error. Try again.', 'bg-red-100');
                    } finally {
                        sendBtn.disabled = false;
                        sendBtn.textContent = 'Send';
                    }
                });
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)
    @section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</body>
</html>
