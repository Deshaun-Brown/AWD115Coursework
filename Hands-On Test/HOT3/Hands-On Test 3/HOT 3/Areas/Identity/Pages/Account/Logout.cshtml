@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md border border-gray-200 animate-3d-slide-in text-center">
    <header>
        <h1 class="text-2xl font-bold mb-4 text-gray-900">@ViewData["Title"]</h1>
        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <form class="inline-block" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">Click here to Logout</button>
                </form>
            }
            else
            {
                <p class="text-gray-700">You have successfully logged out of the application.</p>
            }
        }
    </header>
</div>
