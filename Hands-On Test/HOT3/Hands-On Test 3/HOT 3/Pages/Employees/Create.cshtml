@page
@model HOT_3.Pages.Employees.CreateModel

<h1>Enter New Employee</h1>

<form method="post">
    <div class="text-danger" asp-validation-summary="ModelOnly"></div>
    <div class="form-group">
        <label asp-for="Employee.FirstName"></label>
        <input asp-for="Employee.FirstName" class="form-control" />
        <span asp-validation-for="Employee.FirstName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.LastName"></label>
        <input asp-for="Employee.LastName" class="form-control" />
        <span asp-validation-for="Employee.LastName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.DOB"></label>
        <input asp-for="Employee.DOB" class="form-control" />
        <span asp-validation-for="Employee.DOB" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.DateOfHire"></label>
        <input asp-for="Employee.DateOfHire" class="form-control" />
        <span asp-validation-for="Employee.DateOfHire" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.ManagerId"></label>
        <select asp-for="Employee.ManagerId" asp-items="Model.ManagerList" class="form-control">
            <option value="">Select Manager</option>
        </select>
        <span asp-validation-for="Employee.ManagerId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}