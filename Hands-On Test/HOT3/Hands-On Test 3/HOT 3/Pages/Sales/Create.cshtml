@page
@model HOT_3.Pages.Sales.CreateModel

<h1>Enter New Sales Data</h1>

<form method="post">
    <div class="text-danger" asp-validation-summary="ModelOnly"></div>
    <div class="form-group">
        <label asp-for="SalesData.Quarter"></label>
        <input asp-for="SalesData.Quarter" class="form-control" />
        <span asp-validation-for="SalesData.Quarter" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SalesData.Year"></label>
        <input asp-for="SalesData.Year" class="form-control" />
        <span asp-validation-for="SalesData.Year" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SalesData.Amount"></label>
        <input asp-for="SalesData.Amount" class="form-control" />
        <span asp-validation-for="SalesData.Amount" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SalesData.EmployeeId"></label>
        <select asp-for="SalesData.EmployeeId" asp-items="Model.EmployeeList" class="form-control">
            <option value="">Select Employee</option>
        </select>
        <span asp-validation-for="SalesData.EmployeeId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}