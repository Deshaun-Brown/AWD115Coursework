@model Pharmaceuticals.Models.Product
@{
    ViewData["Title"] = Model.Name;
}
<div class="max-w-2xl mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-lg p-8 flex flex-col items-center">
        <img src="@Model.ImageUrl" alt="@Model.Name" class="h-48 w-48 object-contain rounded-lg border-4 border-yellow-200 bg-yellow-50 mb-6" />
        <h1 class="text-3xl font-bold text-yellow-700 mb-2">@Model.Name</h1>
        <div class="text-lg text-slate-700 mb-4">@Model.Description</div>
        <div class="flex flex-wrap gap-4 mb-4">
            <span class="inline-block rounded bg-yellow-100 px-3 py-1 text-sm font-semibold text-yellow-700">Category: @Model.Category?.Name</span>
            <span class="inline-block rounded bg-green-100 px-3 py-1 text-sm font-semibold text-green-700">Price: $@Model.Price</span>
            <span class="inline-block rounded bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-700">Quantity: @Model.Quantity</span>
        </div>
        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.ProductId" />
            <input type="hidden" name="quantity" value="1" />
            <button type="submit" class="rounded-md bg-yellow-400 px-5 py-2 text-base font-bold text-gray-900 hover:bg-yellow-500 shadow">Add to Cart</button>
        </form>
    </div>
</div>
