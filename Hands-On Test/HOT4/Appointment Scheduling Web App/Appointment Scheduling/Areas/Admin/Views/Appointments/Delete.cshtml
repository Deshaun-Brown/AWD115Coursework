@model Appointment_Scheduling.Models.Appointment

@{
    ViewData["Title"] = "Admin - Delete Appointment";
}

<section class="hero-panel">
    <p class="eyebrow">Danger zone</p>
    <h1 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 2.4rem);">Delete appointment</h1>
    <p class="hero-copy">This action permanently removes the appointment from the schedule.</p>
</section>

<section class="mt-4 rounded border p-6">
    <div class="space-y-2">
        <div><span class="font-medium">Start:</span> @Model.StartDateTime.ToString("g")</div>
        <div><span class="font-medium">Customer:</span> @Model.Customer?.Username</div>
    </div>

    <form asp-action="DeleteConfirmed" method="post" class="mt-4">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="hero-actions">
            <button type="submit" class="theme-button" style="background: linear-gradient(135deg, #ef4444, #f97316);">Delete appointment</button>
            <a asp-action="Index" class="theme-button theme-button-secondary">Cancel</a>
        </div>
    </form>
</section>
