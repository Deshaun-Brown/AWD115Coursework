@model Appointment_Scheduling.Models.Appointment

@{
    ViewData["Title"] = "Create Appointment";
}

<section class="hero-panel">
    <p class="eyebrow">Schedule an appointment</p>
    <h1 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 2.4rem);">Book the next open hour</h1>
    <p class="hero-copy">Appointments must be in the future, begin on the exact hour, and cannot duplicate an existing time slot.</p>
</section>

<section class="mt-4 rounded border p-6">
    <form asp-action="Create" method="post" class="space-y-4">
        <div asp-validation-summary="All" class="text-red-600"></div>

        <div>
            <label asp-for="CustomerId" class="block font-medium">Customer</label>
            <select asp-for="CustomerId" asp-items="ViewBag.CustomerId" class="mt-1 w-full">
                <option value="">-- select --</option>
            </select>
            <span asp-validation-for="CustomerId" class="text-red-600"></span>
        </div>

        <div>
            <label asp-for="StartDateTime" class="block font-medium">Start (on the hour)</label>
            <input asp-for="StartDateTime" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="mt-1 w-full" />
            <span asp-validation-for="StartDateTime" class="text-red-600"></span>
            <div class="text-sm text-gray-600">Appointments are 1 hour long and must start on the exact hour.</div>
        </div>

        <div class="hero-actions">
            <button type="submit" class="theme-button">Create appointment</button>
            <a asp-action="Index" class="theme-button theme-button-secondary">Back to appointments</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
