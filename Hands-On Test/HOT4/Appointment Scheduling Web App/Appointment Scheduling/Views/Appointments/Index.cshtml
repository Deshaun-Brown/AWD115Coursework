@model IReadOnlyList<Appointment_Scheduling.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold">Appointments</h1>
    <a asp-action="Create" class="border px-4 py-2">New Appointment</a>
</div>

<table class="mt-4 w-full border-collapse">
    <thead>
        <tr class="border-b">
            <th class="py-2 text-left">Start</th>
            <th class="py-2 text-left">Customer</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var a in Model)
    {
        <tr class="border-b">
            <td class="py-2">@a.StartDateTime.ToString("g")</td>
            <td class="py-2">@a.Customer?.Username</td>
        </tr>
    }
    </tbody>
</table>
