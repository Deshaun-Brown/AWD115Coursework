@model Appointment_Scheduling.Models.Customer

@{
    ViewData["Title"] = "Create Customer";
}

<section class="hero-panel">
    <p class="eyebrow">Customer creation</p>
    <h1 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 2.4rem);">Add a new customer</h1>
    <p class="hero-copy">Use meaningful usernames and a valid phone number so appointments can be linked cleanly.</p>
</section>

<section class="mt-4 rounded border p-6">
    <form asp-action="Create" method="post" class="space-y-4">
        <div asp-validation-summary="All" class="text-red-600"></div>

        <div>
            <label asp-for="Username" class="block font-medium"></label>
            <input asp-for="Username" class="mt-1 w-full" />
            <span asp-validation-for="Username" class="text-red-600"></span>
        </div>

        <div>
            <label asp-for="PhoneNumber" class="block font-medium"></label>
            <input asp-for="PhoneNumber" class="mt-1 w-full" />
            <span asp-validation-for="PhoneNumber" class="text-red-600"></span>
        </div>

        <div class="hero-actions">
            <button type="submit" class="theme-button">Create customer</button>
            <a asp-action="Index" class="theme-button theme-button-secondary">Back to customers</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
