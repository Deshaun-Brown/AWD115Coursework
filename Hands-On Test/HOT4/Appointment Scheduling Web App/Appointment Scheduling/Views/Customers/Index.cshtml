@model IReadOnlyList<Appointment_Scheduling.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold">Customers</h1>
    <a asp-action="Create" class="border px-4 py-2">New Customer</a>
</div>

<table class="mt-4 w-full border-collapse">
    <thead>
        <tr class="border-b">
            <th class="py-2 text-left">Username</th>
            <th class="py-2 text-left">Phone</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr class="border-b">
            <td class="py-2">@c.Username</td>
            <td class="py-2">@c.PhoneNumber</td>
        </tr>
    }
    </tbody>
</table>
