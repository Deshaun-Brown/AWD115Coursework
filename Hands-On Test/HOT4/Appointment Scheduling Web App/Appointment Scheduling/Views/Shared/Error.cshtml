@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="hero-panel">
    <p class="eyebrow">Application error</p>
    <h1 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 2.4rem);">Something went wrong</h1>
    <p class="hero-copy">An unexpected error occurred while processing your request.</p>
</section>

<section class="mt-4 rounded border p-6">
    @if (Model.ShowRequestId)
    {
        <p class="text-sm text-gray-700">
            <span class="font-medium">Request ID:</span>
            <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4 space-y-2 text-sm text-gray-600">
        <p>For debugging, run the app in Development environment to see full exception details.</p>
        <p>Do not enable detailed errors in production environments.</p>
    </div>
</section>
