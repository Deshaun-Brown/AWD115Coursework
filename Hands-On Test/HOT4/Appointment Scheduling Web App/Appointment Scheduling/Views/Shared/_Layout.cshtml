<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Appointment Scheduling</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container nav-shell">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">Appointment Scheduling</a>

            <div class="nav-actions">
                <nav class="desktop-nav" aria-label="Primary">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="nav-link" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                    <a class="nav-link" asp-area="" asp-controller="Appointments" asp-action="Index">Appointments</a>

                    <details class="nav-dropdown">
                        <summary class="nav-link nav-link-primary">Admin</summary>
                        <div class="nav-dropdown-panel">
                            <a class="nav-dropdown-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Admin Dashboard</a>
                            <a class="nav-dropdown-link" asp-area="Admin" asp-controller="Appointments" asp-action="Index">Manage Appointments</a>
                        </div>
                    </details>
                </nav>

                <details class="mobile-menu">
                    <summary class="menu-toggle" aria-label="Open navigation menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </summary>
                    <div class="menu-panel">
                        <a class="menu-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="menu-link" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                        <a class="menu-link" asp-area="" asp-controller="Appointments" asp-action="Index">Appointments</a>
                        <div class="menu-divider"></div>
                        <a class="menu-link menu-link-primary" asp-area="Admin" asp-controller="Home" asp-action="Index">Admin Dashboard</a>
                        <a class="menu-link" asp-area="Admin" asp-controller="Appointments" asp-action="Index">Manage Appointments</a>
                    </div>
                </details>
            </div>
        </div>
    </header>

    <main class="container app-main">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="mb-4 rounded border p-4" style="border-color: rgba(34, 197, 94, 0.45); background: rgba(34, 197, 94, 0.14);">
                @successMessage
            </div>
        }

        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-shell">
            <span>&copy; 2026 - Appointment Scheduling</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
