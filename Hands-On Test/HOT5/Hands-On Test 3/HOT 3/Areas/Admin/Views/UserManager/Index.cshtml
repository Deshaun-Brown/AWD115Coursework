@model Pharmaceuticals.ViewModels.UserManagerViewModel

@{
    ViewData["Title"] = "User Manager";
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-900">User Manager</h1>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="text-sm font-medium text-blue-600 hover:text-blue-800">Back to Products</a>
    </div>

    @if (TempData["Success"] is string successMessage)
    {
        <div class="mb-4 rounded-md border border-green-200 bg-green-50 p-3 text-green-700">@successMessage</div>
    }

    @if (TempData["Error"] is string errorMessage)
    {
        <div class="mb-4 rounded-md border border-red-200 bg-red-50 p-3 text-red-700">@errorMessage</div>
    }

    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Name</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Email</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Admin</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="px-4 py-3 text-sm text-slate-800">@($"{user.FirstName} {user.LastName}".Trim())</td>
                        <td class="px-4 py-3 text-sm text-slate-700">@user.Email</td>
                        <td class="px-4 py-3 text-sm">
                            @if (user.IsAdmin)
                            {
                                <span class="inline-flex rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-700">Yes</span>
                            }
                            else
                            {
                                <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-700">No</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm">
                            <div class="flex flex-wrap gap-2">
                                @if (user.IsAdmin)
                                {
                                    <form asp-area="Admin" asp-controller="UserManager" asp-action="RemoveFromAdminRole" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-800 hover:bg-amber-200">Remove Admin</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="UserManager" asp-action="AddToAdminRole" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="rounded-md bg-blue-100 px-3 py-1.5 text-xs font-semibold text-blue-800 hover:bg-blue-200">Add to Admin</button>
                                    </form>
                                }

                                <form asp-area="Admin" asp-controller="UserManager" asp-action="DeleteUser" method="post" onsubmit="return confirm('Delete this user?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="rounded-md bg-red-100 px-3 py-1.5 text-xs font-semibold text-red-800 hover:bg-red-200">Delete User</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
