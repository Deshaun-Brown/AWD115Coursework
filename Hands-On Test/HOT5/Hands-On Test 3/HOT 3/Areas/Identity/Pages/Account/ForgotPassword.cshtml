@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg border border-gray-200 animate-3d-slide-in">
    <h1 class="text-2xl font-bold mb-6 text-center text-gray-900">@ViewData["Title"]</h1>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="mb-4 rounded-md border border-green-200 bg-green-50 p-3 text-sm text-green-700">@Model.StatusMessage</div>
    }

    <form method="post" class="space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm" role="alert"></div>

        <div>
            <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Input.Email" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="name@example.com" />
            <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.OldPassword" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Input.OldPassword" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="old password" />
            <span asp-validation-for="Input.OldPassword" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Input.NewPassword" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="new password" />
            <span asp-validation-for="Input.NewPassword" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Input.ConfirmPassword" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="confirm new password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-sm"></span>
        </div>

        <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700">
            Replace Password
        </button>

        <p class="text-center text-sm">
            <a asp-page="./Login" class="font-medium text-blue-600 hover:text-blue-500">Back to Login</a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
