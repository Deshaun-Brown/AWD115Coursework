@model Pharmaceuticals.Models.Order

@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="max-w-4xl mx-auto mt-8 mb-16">
    <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
        <div class="px-4 py-5 sm:px-6 bg-green-50">
            <h3 class="text-lg leading-6 font-medium text-green-800">
                Thank you for your order!
            </h3>
            <p class="mt-1 max-w-2xl text-sm text-green-700">
                Your order #@Model.OrderId has been placed successfully.
            </p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2">
                <div class="sm:col-span-1">
                    <dt class="text-sm font-medium text-gray-500">Order Date</dt>
                    <dd class="mt-1 text-sm text-gray-900">@Model.OrderDate.ToString("f")</dd>
                </div>
                <div class="sm:col-span-1">
                    <dt class="text-sm font-medium text-gray-500">Status</dt>
                    <dd class="mt-1 text-sm text-gray-900">@Model.Status</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-sm font-medium text-gray-500">Order Details</dt>
                    <dd class="mt-1 text-sm text-gray-900">
                        <ul role="list" class="border border-gray-200 rounded-md divide-y divide-gray-200 mt-2">
                            @foreach (var item in Model.OrderItems)
                            {
                                <li class="pl-3 pr-4 py-3 flex items-center justify-between text-sm">
                                    <div class="w-0 flex-1 flex items-center">
                                        <span class="ml-2 flex-1 w-0 truncate">
                                            @item.Quantity x @(item.Product?.Name ?? "Unknown Product") 
                                            <span class="text-gray-500 text-xs ml-2">(@item.Price.ToString("C") each)</span>
                                        </span>
                                    </div>
                                    <div class="ml-4 flex-shrink-0 font-medium">
                                        @((item.Quantity * item.Price).ToString("C"))
                                    </div>
                                </li>
                            }
                        </ul>
                    </dd>
                </div>
                <div class="sm:col-span-2 flex justify-end">
                    <dt class="text-base font-bold text-gray-900 mr-4">Total Amount:</dt>
                    <dd class="text-base font-bold text-gray-900">@Model.TotalAmount.ToString("C")</dd>
                </div>
            </dl>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6 flex justify-between">
            <a asp-controller="Order" asp-action="Browse" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">
                Continue Shopping
            </a>
        </div>
    </div>
</div>