@model IEnumerable<Pharmaceuticals.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="flex flex-col gap-6">

    {{!-- Top bar --}}
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-medium tracking-tight">Products</h1>
            <p class="mt-1 text-sm text-slate-500">Manage products in your database.</p>
        </div>
        <a asp-action="Create"
               class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
            + Add product
        </a>
    </div>

    {{!-- Stats row --}}
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-lg bg-slate-100 p-4">
            <p class="text-xs text-slate-500">Total products</p>
            <p class="mt-1 text-2xl font-medium text-indigo-700">@Model.Count()</p>
        </div>
        <div class="rounded-lg bg-slate-100 p-4">
            <p class="text-xs text-slate-500">Total value</p>
            <p class="mt-1 text-2xl font-medium text-green-700">
                $@Model.Sum(p => p.Price * p.Quantity).ToString("N2")
            </p>
        </div>
        <div class="rounded-lg bg-slate-100 p-4">
            <p class="text-xs text-slate-500">Low stock (&lt;5)</p>
            <p class="mt-1 text-2xl font-medium text-amber-700">@Model.Count(p => p.Quantity < 5)</p>
        </div>
        <div class="rounded-lg bg-slate-100 p-4">
            <p class="text-xs text-slate-500">SKUs</p>
            <p class="mt-1 text-2xl font-medium">@Model.Count()</p>
        </div>
    </div>

    {{!-- Main two-column grid --}}
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">

        {{!-- Featured / hero card --}}
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <img src="~/images/hero-fitness.jpg" alt="Fitness equipment"
                 class="h-44 w-full object-cover" />
            <div class="p-5">
                <h2 class="text-base font-medium">Featured</h2>
                <p class="mt-1 text-sm text-slate-500">
                    Static image loaded from <code class="text-xs bg-slate-100 px-1 py-0.5 rounded">wwwroot/images</code>.
                    Fully styled with Tailwind — no Bootstrap required.
                </p>
            </div>
        </div>

        {{!-- Compact product list --}}
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <div class="flex items-center justify-between border-b border-slate-200 px-5 py-3.5">
                <h2 class="text-sm font-medium">All products</h2>
                <span class="text-xs text-slate-400">Edit / Delete</span>
            </div>
            <ul class="divide-y divide-slate-100">
                @foreach (var p in Model)
                {
                    <li class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition-colors">
                        @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" alt="@p.Name"
                                 class="h-8 w-8 rounded-full object-cover shrink-0" />
                        }
                        else
                        {
                            <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center text-xs text-slate-400 shrink-0">—</span>
                        }
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-medium">@p.Name</p>
                            <p class="truncate text-xs text-slate-400">@p.Description</p>
                        </div>
                        <span class="shrink-0 rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">
                            Qty: @p.Quantity
                        </span>
                        <span class="shrink-0 text-sm font-medium text-green-700">$@p.Price</span>
                        <div class="flex shrink-0 gap-1.5">
                            <a asp-action="Edit" asp-route-id="@p.ProductId" asp-route-slug="@p.Slug"
                                   class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 hover:bg-indigo-100">
                                Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@p.ProductId" asp-route-slug="@p.Slug"
                                   class="rounded-full bg-rose-50 px-3 py-1 text-xs font-medium text-rose-700 hover:bg-rose-100">
                                Delete
                            </a>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>

    {{!-- Bubble grid (full width below) --}}
    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
        <div class="flex items-center justify-between border-b border-slate-200 px-5 py-3.5">
            <h2 class="text-sm font-medium">Bubble view</h2>
            <span class="text-xs text-slate-400">Hover to edit or delete</span>
        </div>
        <div class="grid grid-cols-2 gap-4 p-5 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
            @foreach (var p in Model)
            {
                <div class="group relative flex flex-col items-center rounded-full border border-slate-200 bg-white p-5
                    aspect-square justify-center text-center
                    transition-all duration-200 hover:border-indigo-200 hover:bg-indigo-50 hover:scale-105 cursor-pointer">
                    @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" alt="@p.Name"
                             class="mb-2 h-10 w-10 rounded-full object-cover" />
                    }
                    else
                    {
                        <span class="mb-2 h-10 w-10 rounded-full bg-slate-100 flex items-center justify-center text-xs text-slate-400">—</span>
                    }
                    <p class="text-xs font-medium text-amber-700 leading-tight line-clamp-1">@p.Name</p>
                    <p class="text-sm font-medium text-green-700 mt-0.5">$@p.Price</p>
                    <div class="absolute bottom-2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        <a asp-action="Edit" asp-route-id="@p.ProductId" asp-route-slug="@p.Slug"
                               class="rounded-full bg-white px-2.5 py-0.5 text-xs font-medium text-indigo-700 shadow-sm border border-indigo-100 hover:bg-indigo-50">
                            Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@p.ProductId" asp-route-slug="@p.Slug"
                               class="rounded-full bg-white px-2.5 py-0.5 text-xs font-medium text-rose-700 shadow-sm border border-rose-100 hover:bg-rose-50">
                            Del
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

</div>