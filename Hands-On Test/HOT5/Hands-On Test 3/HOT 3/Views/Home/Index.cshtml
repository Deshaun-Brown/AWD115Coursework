@model Pharmaceuticals.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="mx-auto max-w-6xl py-8">
    <div class="bg-gradient-to-r from-yellow-100 to-yellow-50 rounded-2xl shadow-lg p-8 flex flex-col md:flex-row items-center gap-8 mb-12">
        <div class="flex-1">
            <h1 class="text-5xl font-bold text-yellow-700 mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10" fill="#FFD600"/></svg>
                GoodRx Drug Savings
            </h1>
            <p class="text-lg text-slate-700 mb-6">Save on your prescriptions. Compare prices, find coupons, and manage your medications.</p>
            <div class="flex flex-wrap gap-3">
                <a href="/products" class="rounded-md bg-yellow-400 px-6 py-3 text-lg font-bold text-gray-900 hover:bg-yellow-500 shadow transition">Browse All Products</a>
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="rounded-md border border-yellow-300 bg-white px-5 py-2.5 text-base font-bold text-yellow-700 shadow hover:bg-yellow-50">Add a Drug</a>
                    }
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="rounded-md border border-yellow-300 bg-white px-5 py-2.5 text-base font-bold text-yellow-700 shadow hover:bg-yellow-50">Login</a>
                }
            </div>
        </div>
        <div class="flex-shrink-0">
            <img src="/images/amoxicillin.jpg" alt="Amoxicillin" class="h-48 w-48 object-contain rounded-xl border-4 border-yellow-200 bg-white shadow-md" />
        </div>
    </div>

    <div class="mb-12">
        <h2 class="text-2xl font-bold text-yellow-700 mb-4">Featured Drugs</h2>
        <div class="overflow-x-auto">
            <div class="flex gap-8 animate-carousel group hover:[animation-play-state:paused]">
                @foreach (var prod in Model.Products.Take(8))
                {
                    <div class="min-w-[320px] max-w-[320px] bg-white rounded-xl border border-yellow-200 shadow p-4 flex flex-col items-center text-center">
                        <img src="@prod.ImageUrl" alt="@prod.Name" class="h-24 w-24 object-contain rounded-lg border-2 border-yellow-100 bg-yellow-50 mb-2" />
                        <div class="text-lg font-bold text-yellow-700 mb-1">@prod.Name</div>
                        <div class="text-xs text-slate-500 mb-2">@prod.Category?.Name</div>
                        <div class="text-base text-slate-700 mb-2 line-clamp-2">@prod.Description</div>
                        <div class="text-lg font-bold text-green-700 mb-2">$@prod.Price</div>
                        <a href="/products" class="rounded bg-yellow-300 px-3 py-1 text-sm font-semibold text-gray-900 hover:bg-yellow-400">View</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- New Section: Prescription Info -->
    <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col md:flex-row items-center gap-8 mb-12 border border-yellow-100">
        <div class="flex-shrink-0 order-2 md:order-1">
            <img src="/images/medicine-on-blank-prescription-form-free-photo.jpg" alt="Medicine on Prescription Form" class="h-56 w-56 object-cover rounded-xl border-4 border-yellow-200 bg-white shadow-md" />
        </div>
        <div class="flex-1 order-1 md:order-2">
            <h2 class="text-3xl font-bold text-yellow-700 mb-3 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="4" y="4" width="16" height="16" rx="4" fill="#FFD600"/></svg>
                Prescription Management
            </h2>
            <p class="text-lg text-slate-700 mb-4">Easily upload, track, and refill your prescriptions. Our platform helps you manage your medication schedule and keep your health on track.</p>
            <ul class="list-disc pl-6 text-slate-600 mb-4">
                <li>Upload and store prescription forms securely</li>
                <li>Get reminders for refills and renewals</li>
                <li>Access your prescription history anytime</li>
            </ul>
            <a href="/products" class="inline-block rounded-md bg-yellow-400 px-5 py-2.5 text-base font-bold text-gray-900 hover:bg-yellow-500 shadow">Explore Medications</a>
        </div>
    </div>
</div>
