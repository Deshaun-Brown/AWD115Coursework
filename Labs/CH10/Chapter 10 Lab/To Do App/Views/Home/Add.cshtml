@model To_Do_App.Models.ToDo
@{
    ViewData["Title"] = "Add Task";
}

<div class="max-w-3xl mx-auto bg-white p-6 rounded shadow">
    <h2 class="text-2xl font-semibold text-center mb-6">New Task</h2>

    <form asp-action="Add" method="post" class="space-y-4">
        <div>
            <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700">Category</label>
            <select asp-for="CategoryId" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2" asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "Name"))">
                <option value="">Select a category</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm font-medium text-gray-700">Description</label>
            <input asp-for="Description" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2" />
            <span asp-validation-for="Description" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="DueDate" class="block text-sm font-medium text-gray-700">Due Date</label>
            <input asp-for="DueDate" type="date" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2" />
            <span asp-validation-for="DueDate" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="StatusId" class="block text-sm font-medium text-gray-700">Status</label>
            <select asp-for="StatusId" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2" asp-items="@(new SelectList(ViewBag.Statuses, "StatusId", "Name"))">
                <option value="">Select a status</option>
            </select>
            <span asp-validation-for="StatusId" class="text-sm text-red-600"></span>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="inline-flex items-center px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700">Add task</button>
            <a asp-action="Index" class="inline-flex items-center px-4 py-2 rounded bg-gray-200 text-gray-800 hover:bg-gray-300">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
