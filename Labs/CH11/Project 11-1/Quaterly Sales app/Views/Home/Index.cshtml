@model List<Sales>
@{
    ViewData["Title"] = "Quarterly Sales";
}

<div class="container mx-auto p-4">
    <h1 class="text-3xl font-bold mb-6">@ViewData["Title"]</h1>

    @if (TempData["message"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["message"]</span>
        </div>
    }

    <form asp-action="Index" method="get" class="mb-6">
        <label for="id" class="mr-2 font-medium text-gray-700">Filter by Employee:</label>
        <select name="id" class="border border-gray-300 rounded-md shadow-sm p-2" onchange="this.form.submit()">
            @foreach (var emp in ViewBag.Employees)
            {
                if (emp.EmployeeId == ViewBag.EmployeeId)
                {
                    <option value="@emp.EmployeeId" selected>@emp.Firstname @emp.Lastname</option>
                }
                else
                {
                    <option value="@emp.EmployeeId">@emp.Firstname @emp.Lastname</option>
                }
            }
        </select>
    </form>

    <div class="overflow-x-auto bg-white shadow-md rounded-lg">
        <table class="min-w-full leading-normal">
            <thead>
                <tr>
                    <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        Employee
                    </th>
                    <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        Year
                    </th>
                    <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        Quarter
                    </th>
                    <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        Amount
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in Model)
                {
                    <tr>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">
                                @sale.Employee?.Firstname @sale.Employee?.Lastname
                            </p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">
                                @sale.Year
                            </p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">Q@sale.Quarter</p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm text-right">
                            <p class="text-gray-900 whitespace-no-wrap">@sale.Amount.ToString("c")</p>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="px-5 py-3 border-t-2 border-gray-200 bg-gray-50 text-right font-bold text-gray-700">Total Sales:</td>
                    <td class="px-5 py-3 border-t-2 border-gray-200 bg-gray-50 text-right font-bold text-gray-900">@Model.Sum(s => s.Amount).ToString("c")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
