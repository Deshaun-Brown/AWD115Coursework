<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Trip Log</title>
    <!-- Add Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Home" asp-action="Index">View Trips</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Manage" asp-action="Destinations">Manage Destinations</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Manage" asp-action="Accommodations">Manage Accommodations</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Manage" asp-action="Activities">Manage Activities</a>
                </li>
            </ul>
        </div>
    </nav>

    <header class="bg-secondary text-white text-center py-4 mb-4">
        <h1 class="display-3">My Trip Log</h1>
        @if (!string.IsNullOrWhiteSpace(ViewBag.SubHeader as string))
        {
            <div class="subhead lead">@ViewBag.SubHeader</div>
        }
    </header>

    <main class="container">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
