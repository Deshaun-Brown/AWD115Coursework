@model Author
@{
    ViewData["Title"] = "Delete Author";
}

<h1 class="mb-4 text-2xl font-semibold text-red-700">Delete Author</h1>
<div class="rounded-lg bg-white p-4 shadow-sm">
    <p>Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
    <div asp-validation-summary="ModelOnly" class="mt-2 text-red-600"></div>
    <form asp-action="Delete" method="post" class="mt-4 flex gap-2">
        <input asp-for="Id" type="hidden" />
        <button class="rounded bg-red-700 px-4 py-2 text-sm text-white" type="submit">Delete</button>
        <a asp-action="Index" class="rounded border px-4 py-2 text-sm">Cancel</a>
    </form>
</div>
