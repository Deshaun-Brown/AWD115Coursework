@model Book
@{
    ViewData["Title"] = "Staff Pick";
}

<section class="space-y-4">
    <h1 class="text-2xl font-semibold">Staff Pick</h1>

    <div class="rounded-lg bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">@Model.Title</h2>
        <p class="mt-2 text-sm text-slate-600">Author: @Model.Author.FullName</p>
        <p class="text-sm text-slate-600">Genre: @Model.Genre.Name</p>
        <p class="text-sm text-slate-600">ISBN: @Model.Isbn</p>
        <p class="text-sm text-slate-600">Published: @Model.PublishDate.ToString("MMMM dd, yyyy")</p>
        <p class="mt-3 text-lg font-semibold text-slate-900">@Model.Price.ToString("C")</p>

        <div class="mt-4 flex gap-3">
            <a asp-action="StaffPick" class="rounded bg-slate-900 px-4 py-2 text-sm text-white">Pick Another</a>
            <a asp-action="Index" class="rounded border px-4 py-2 text-sm">Back to Books</a>
        </div>
    </div>
</section>