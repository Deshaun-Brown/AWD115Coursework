@model Bookstore_App.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Cart";
}

<section class="space-y-4">
    <h1 class="text-2xl font-semibold text-slate-900">Your Cart</h1>

    @if (!Model.Items.Any())
    {
        <p class="text-slate-700">Your cart is empty.</p>
        <a asp-controller="Book" asp-action="Index" class="text-blue-600 hover:underline">Browse books</a>
    }
    else
    {
        <div class="overflow-x-auto rounded border border-slate-300 bg-white">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-100 text-slate-800">
                    <tr>
                        <th class="border-b border-slate-300 px-3 py-2">Title</th>
                        <th class="border-b border-slate-300 px-3 py-2">Price</th>
                        <th class="border-b border-slate-300 px-3 py-2">Qty</th>
                        <th class="border-b border-slate-300 px-3 py-2">Subtotal</th>
                        <th class="border-b border-slate-300 px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="border-b border-slate-200">
                            <td class="px-3 py-2">@item.Title</td>
                            <td class="px-3 py-2">@item.Price.ToString("c")</td>
                            <td class="px-3 py-2">@item.Quantity</td>
                            <td class="px-3 py-2">@item.Subtotal.ToString("c")</td>
                            <td class="px-3 py-2">
                                <form asp-action="Remove" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.BookId" />
                                    <button type="submit" class="rounded bg-red-500 px-3 py-1 text-white hover:bg-red-600">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="px-3 py-2 text-right font-semibold">Total</td>
                        <td class="px-3 py-2 font-semibold">@Model.Total.ToString("c")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</section>
